<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PRIMARY BUTTON -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource NavyBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource WhiteBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="20,12"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#2D3561"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#0D1128"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background" Value="#3A4060"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- OUTLINE BUTTON -->
    <Style x:Key="OutlineButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource NavyBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource NavyBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="16,10"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#EFF1F8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SIDEBAR MENU BUTTON -->
    <Style x:Key="SideMenuButtonStyle" TargetType="Button">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="BorderBrush"                Value="Transparent"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Foreground"                 Value="#9DA3C0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"                    Value="18,10"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="FontFamily"                 Value="Segoe UI"/>
        <Setter Property="FontSize"                   Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="MenuBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Margin="8,1,8,1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MenuBorder" Property="Background" Value="#1E2448"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ROLE TOGGLE BUTTON
        ─────────────────
        DEFAULT  (unchecked): transparent bg, dimmed text, dark border
        CHECKED            : gold fill #C9A84C, white text
        HOVER on unchecked : subtle dark highlight
    -->
    <Style x:Key="RoleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#6B7080"/>
        <Setter Property="BorderBrush"     Value="#3A4060"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,8"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="RoleBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- CHECKED = gold fill -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RoleBorder" Property="Background" Value="#C9A84C"/>
                            <Setter TargetName="RoleBorder" Property="BorderBrush"  Value="#C9A84C"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <!-- HOVER on unchecked only -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked"   Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RoleBorder" Property="Background" Value="#1E2448"/>
                            <Setter TargetName="RoleBorder" Property="BorderBrush" Value="#4A5080"/>
                            <Setter Property="Foreground" Value="#9DA3C0"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
