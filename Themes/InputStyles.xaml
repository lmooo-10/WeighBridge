<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════
         TEXTBOX — Standard input field
    ══════════════════════════════════════════════════════ -->
    <Style x:Key="DPTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background"      Value="{StaticResource InputBgBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource NavyBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,10"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="CaretBrush"      Value="{StaticResource NavyBrush}"/>
        <Setter Property="SelectionBrush"  Value="#C9A84C"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                    Value="{StaticResource NavyBrush}"/>
                            <Setter TargetName="InputBorder" Property="BorderThickness"
                                    Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                    Value="{StaticResource MidGrayBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         PASSWORD BOX
    ══════════════════════════════════════════════════════ -->
    <Style x:Key="DPPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Background"      Value="{StaticResource InputBgBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource NavyBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,10"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="PassBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PassBorder" Property="BorderBrush"
                                    Value="{StaticResource NavyBrush}"/>
                            <Setter TargetName="PassBorder" Property="BorderThickness"
                                    Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         COMBOBOX — Standard dropdown
    ══════════════════════════════════════════════════════ -->
    <Style x:Key="DPComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource InputBgBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource NavyBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Height"          Value="40"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         CARD BORDER — White card with rounded corners
    ══════════════════════════════════════════════════════ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CardBgBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
        <Setter Property="Padding"         Value="20"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         DARK CARD — Navy background (e.g. Live Weight panel)
    ══════════════════════════════════════════════════════ -->
    <Style x:Key="DarkCardStyle" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource NavyBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding"      Value="20"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         INPUT LABEL — Small uppercase label above input fields
    ══════════════════════════════════════════════════════ -->
    <Style x:Key="InputLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{StaticResource MidGrayBrush}"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

</ResourceDictionary>
