<UserControl x:Class="WeighBridge.Views.UserControls.ContainerTrackingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F4F6F9">

    <UserControl.Resources>
        <!-- Card style -->
        <Style x:Key="TrackCard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="BorderBrush"     Value="#E4E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                      Color="#22000000" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="#8A8E9B"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Foreground"  Value="#8A8E9B"/>
        </Style>

        <!-- Field value -->
        <Style x:Key="FieldVal" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="#1A1F3A"/>
        </Style>

        <!-- Search TextBox -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Height"                  Value="36"/>
            <Setter Property="Padding"                 Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background"              Value="White"/>
            <Setter Property="BorderBrush"             Value="#D0D5E0"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#1A1F3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Filter ComboBox -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Height"      Value="36"/>
            <Setter Property="Padding"     Value="8,0"/>
            <Setter Property="BorderBrush" Value="#D0D5E0"/>
        </Style>

        <!-- Action button base -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1A1F3A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#E8001D"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#EEF0F6"/>
            <Setter Property="Foreground" Value="#1A1F3A"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- KPI cards -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0 — Header ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="4" Height="28" Background="#E8001D"
                            CornerRadius="2" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Suivi Conteneurs en Temps Réel"
                               FontFamily="Segoe UI" FontSize="24" FontWeight="Bold"
                               Foreground="#1A1F3A" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Suivi conteneur en temps réel · Statut (en attente / pesé / sorti) · Historique par conteneur"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#8A8E9B"
                           Margin="16,0,0,0"/>
            </StackPanel>
            <!-- Action buttons top-right -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource GhostBtn}" Margin="0,0,8,0"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↻ " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Actualiser" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryBtn}"
                        Command="{Binding ExportCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓ " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Exporter CSV" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ ROW 1 — KPI Cards ═══ -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">

            <!-- Total -->
            <Border Style="{StaticResource TrackCard}" Margin="0,0,12,0" Padding="16,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#1A1F3A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="TOTAL" Style="{StaticResource SectionLabel}" Margin="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalContainers}"
                               FontFamily="Segoe UI" FontSize="32" FontWeight="ExtraBold"
                               Foreground="#1A1F3A"/>
                    <TextBlock Text="Conteneurs" Style="{StaticResource FieldLbl}"/>
                </StackPanel>
            </Border>

            <!-- En attente -->
            <Border Style="{StaticResource TrackCard}" Margin="0,0,12,0" Padding="16,14"
                    BorderThickness="0,0,0,3" BorderBrush="#E67E22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#E67E22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="EN ATTENTE" Style="{StaticResource SectionLabel}" Margin="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding EnAttenteCount}"
                               FontFamily="Segoe UI" FontSize="32" FontWeight="ExtraBold"
                               Foreground="#E67E22"/>
                    <TextBlock Text="En file / gate-in" Style="{StaticResource FieldLbl}"/>
                </StackPanel>
            </Border>

            <!-- Pesé -->
            <Border Style="{StaticResource TrackCard}" Margin="0,0,12,0" Padding="16,14"
                    BorderThickness="0,0,0,3" BorderBrush="#2ECC71">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#2ECC71" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PESÉ" Style="{StaticResource SectionLabel}" Margin="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding PeseCount}"
                               FontFamily="Segoe UI" FontSize="32" FontWeight="ExtraBold"
                               Foreground="#2ECC71"/>
                    <TextBlock Text="Pesée effectuée" Style="{StaticResource FieldLbl}"/>
                </StackPanel>
            </Border>

            <!-- Sorti -->
            <Border Style="{StaticResource TrackCard}" Padding="16,14"
                    BorderThickness="0,0,0,3" BorderBrush="#9DA3C0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="#9DA3C0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SORTI" Style="{StaticResource SectionLabel}" Margin="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SortiCount}"
                               FontFamily="Segoe UI" FontSize="32" FontWeight="ExtraBold"
                               Foreground="#9DA3C0"/>
                    <TextBlock Text="Quittés la terminale" Style="{StaticResource FieldLbl}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ ROW 2 — Search & Filter Toolbar ═══ -->
        <Border Grid.Row="2" Style="{StaticResource TrackCard}" Margin="0,0,0,16" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource SearchBox}"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
             x:Name="SearchBox"/>
                    <TextBlock Text="🔍  Search by container, vehicle, driver..."
               FontFamily="Segoe UI" FontSize="13"
               Foreground="#B0B5C8" IsHitTestVisible="False"
               VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <!-- Placeholder effect via tag -->

                <!-- Status Filter -->
                <ComboBox Grid.Column="2"
          ItemsSource="{Binding StatusFilters}"
          SelectedItem="{Binding StatusFilter}">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,4">
                                <Border Width="10" Height="10" CornerRadius="5"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A1F3A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="En attente">
                                                    <Setter Property="Background" Value="#E67E22"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Pesé">
                                                    <Setter Property="Background" Value="#2ECC71"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Sorti">
                                                    <Setter Property="Background" Value="#9DA3C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1A1F3A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="En attente">
                                                    <Setter Property="Foreground" Value="#E67E22"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Pesé">
                                                    <Setter Property="Foreground" Value="#2ECC71"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Sorti">
                                                    <Setter Property="Foreground" Value="#9DA3C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Direction Filter placeholder label -->

            </Grid>
        </Border>
        <!-- ═══ ROW 3 — Main Content: Table left + Detail right ═══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <!-- Detail panel — visible when a container is selected -->
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            <!-- ── LEFT: Container table ── -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Border Grid.Column="0" Style="{StaticResource TrackCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Table header bar -->
                            <Border Grid.Row="0" Background="#1A1F3A" CornerRadius="10,10,0,0" Padding="0,0,0,0">
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Header cells -->
                                    <TextBlock Grid.Column="0" Text="CONTENEUR" Foreground="White" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="14,10"/>
                                    <TextBlock Grid.Column="1" Text="TYPE"      Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="2" Text="SENS"      Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="3" Text="STATUT"    Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="4" Text="VÉHICULE"  Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="5" Text="CHAUFFEUR" Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="6" Text="BRUT (MT)" Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="7" Text="NET (MT)"  Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="8" Text="ENTRÉE"    Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                    <TextBlock Grid.Column="9" Text=""           Foreground="#9DA3C0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Padding="4,10"/>
                                </Grid>
                            </Border>

                            <!-- DataGrid rows -->
                            <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredContainers}"
                              SelectedItem="{Binding SelectedContainer}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="None"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F2F8"
                              Background="White"
                              BorderThickness="0"
                              RowHeight="50"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              SelectionMode="Single">

                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FontFamily"   Value="Segoe UI"/>
                                        <Setter Property="FontSize"     Value="13"/>
                                        <Setter Property="Background"   Value="White"/>
                                        <Setter Property="Foreground"   Value="#1A1F3A"/>
                                        <Setter Property="BorderBrush"  Value="#F0F2F8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8F9FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EEF0FF"/>
                                                <Setter Property="Foreground" Value="#1A1F3A"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Background="Transparent"
                                                    Padding="4,0">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <!-- Container Number -->
                                    <DataGridTemplateColumn Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding ContainerNumber}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       FontWeight="Bold" Foreground="#1A1F3A"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Type -->
                                    <DataGridTemplateColumn Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,3"
                                                HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F0F2F8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="20' REEF">
                                                                    <Setter Property="Background" Value="#E0F7FA"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="20' DGR">
                                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="40' STD">
                                                                    <Setter Property="Background" Value="#EDE7F6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Type}" FontFamily="Segoe UI"
                                                       FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#4A5080"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="20' REEF">
                                                                        <Setter Property="Foreground" Value="#00838F"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="20' DGR">
                                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="40' STD">
                                                                        <Setter Property="Foreground" Value="#6A1B9A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Direction -->
                                    <DataGridTemplateColumn Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center" FontSize="14"
                                                       Margin="0,0,4,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="↓"/>
                                                                <Setter Property="Foreground" Value="#fc539d"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Direction}" Value="Export">
                                                                        <Setter Property="Text" Value="↑"/>
                                                                        <Setter Property="Foreground" Value="#4bd9ed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Direction}"
                                                       FontFamily="Segoe UI" FontSize="12"
                                                       VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#fc539d"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Direction}" Value="Export">
                                                                        <Setter Property="Foreground" Value="#4bd9ed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Status badge -->
                                    <DataGridTemplateColumn Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="20" Padding="10,4"
                                                HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pese">
                                                                    <Setter Property="Background" Value="#E8F8EF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Sorti">
                                                                    <Setter Property="Background" Value="#F0F2F8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6"
                                                         VerticalAlignment="Center" Margin="0,0,5,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#E67E22"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Pese">
                                                                            <Setter Property="Fill" Value="#2ECC71"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Sorti">
                                                                            <Setter Property="Fill" Value="#9DA3C0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#E67E22"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Pese">
                                                                            <Setter Property="Foreground" Value="#27AE60"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Sorti">
                                                                            <Setter Property="Foreground" Value="#8A8E9B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Vehicle -->
                                    <DataGridTextColumn Binding="{Binding VehicleNumber}" Width="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize"   Value="12"/>
                                                <Setter Property="Foreground" Value="#1A1F3A"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Driver -->
                                    <DataGridTextColumn Binding="{Binding DriverName}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize"   Value="12"/>
                                                <Setter Property="Foreground" Value="#4A5080"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Gross -->
                                    <DataGridTemplateColumn Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding GrossWeight, StringFormat='{}{0:F2}'}"
                                                   FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="#1A1F3A" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Net -->
                                    <DataGridTemplateColumn Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NetWeightDisplay}"
                                                   FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                                   Foreground="#2ECC71" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Entry time -->
                                    <DataGridTemplateColumn Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding EntryTime, StringFormat='HH:mm'}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="#8A8E9B" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Detail arrow -->
                                    <DataGridTemplateColumn Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="›" FontSize="20"
                                                   Foreground="#C0C5D8"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
            <!-- ── RIGHT: Container Detail Panel ── -->
            <Border Grid.Column="2" Style="{StaticResource TrackCard}" Padding="0">
                <!-- Empty state -->
                <Grid>
                    <!-- No selection placeholder: visible when nothing selected -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasSelectedContainer,
                                    Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Text="⊡" FontSize="40" Foreground="#D0D5E0"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Sélectionnez un conteneur" FontFamily="Segoe UI"
                                   FontSize="13" Foreground="#8A8E9B" HorizontalAlignment="Center"/>
                        <TextBlock Text="pour voir le détail et l'historique"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#B0B5C8" HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Detail content: visible when a container IS selected -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"  
                                  Visibility="{Binding SelectedContainer,
                                      Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel DataContext="{Binding SelectedContainer}">

                            <!-- Detail header -->
                            <Border Background="#1A1F3A" CornerRadius="10,10,0,0" Padding="16,14">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ContainerNumber}"
                                                   FontFamily="Consolas" FontSize="15"
                                                   FontWeight="Bold" Foreground="White"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="#9DA3C0" Margin="0,2,0,0">
                                            <Run Text="{Binding Type}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Direction}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- Status badge top-right -->
                                    <Border CornerRadius="20" Padding="10,4"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#3D2A10"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pese">
                                                        <Setter Property="Background" Value="#0D2E1A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Sorti">
                                                        <Setter Property="Background" Value="#252B50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusLabel}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#E67E22"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pese">
                                                            <Setter Property="Foreground" Value="#2ECC71"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Sorti">
                                                            <Setter Property="Foreground" Value="#9DA3C0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Weight summary strip -->
                            <Border Background="#F8F9FF" Padding="16,12"
                                    BorderBrush="#E4E8F0" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="BRUT" FontFamily="Segoe UI" FontSize="10"
                                                   FontWeight="Bold" Foreground="#8A8E9B"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding GrossWeight, StringFormat='{}{0:F2}'}"
                                                   FontFamily="Segoe UI" FontSize="18"
                                                   FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="MT" FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="#8A8E9B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="TARE" FontFamily="Segoe UI" FontSize="10"
                                                   FontWeight="Bold" Foreground="#8A8E9B"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding TareWeight, StringFormat='{}{0:F2}'}"
                                                   FontFamily="Segoe UI" FontSize="18"
                                                   FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="MT" FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="#8A8E9B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="NET" FontFamily="Segoe UI" FontSize="10"
                                                   FontWeight="Bold" Foreground="#8A8E9B"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding NetWeightDisplay}"
                                                   FontFamily="Segoe UI" FontSize="18"
                                                   FontWeight="Bold" Foreground="#2ECC71"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="MT" FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="#8A8E9B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Operator info -->
                            <StackPanel Margin="16,14,16,0">
                                <TextBlock Text="INFORMATIONS OPÉRATION" FontFamily="Segoe UI"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#8A8E9B" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Véhicule"
                                               Style="{StaticResource FieldLbl}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding VehicleNumber}"
                                               Style="{StaticResource FieldVal}"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Chauffeur"
                                               Style="{StaticResource FieldLbl}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DriverName}"
                                               Style="{StaticResource FieldVal}"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Emplacement"
                                               Style="{StaticResource FieldLbl}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Location}"
                                               Style="{StaticResource FieldVal}"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Remarques"
                                               Style="{StaticResource FieldLbl}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Remarks}"
                                               Style="{StaticResource FieldVal}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>

                            <!-- Separator -->
                            <Border Height="1" Background="#E4E8F0" Margin="16,12,16,0"/>

                            <!-- ── Historique par conteneur ── -->
                            <StackPanel Margin="16,14,16,16">
                                <TextBlock Text="HISTORIQUE PAR CONTENEUR" FontFamily="Segoe UI"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#8A8E9B" Margin="0,0,0,12"/>

                                <!-- Timeline step: Entrée -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>

                                    <!-- dot -->
                                    <Border Grid.Column="0" Grid.Row="0"
                                            Width="12" Height="12" CornerRadius="6"
                                            Background="#1A1F3A" HorizontalAlignment="Center"
                                            VerticalAlignment="Top" Margin="0,3,0,0"/>
                                    <!-- connector line -->
                                    <Border Grid.Column="0" Grid.Row="1"
                                            Width="2" Background="#E4E8F0"
                                            HorizontalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                                        <TextBlock Text="Entrée Terminale" FontFamily="Segoe UI"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#1A1F3A"/>
                                        <TextBlock Text="{Binding EntryTime, StringFormat='dd MMM yyyy · HH:mm'}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="#8A8E9B"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Timeline step: Pesée -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Column="0" Grid.Row="0"
                                            Width="12" Height="12" CornerRadius="6"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top" Margin="0,3,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A1F3A"/>
                                                <!-- ← colored when not null -->
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WeighTime}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="#E4E8F0"/>
                                                        <!-- grey when null -->
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Grid.Column="0" Grid.Row="1"
                                            Width="2" Background="#E4E8F0"
                                            HorizontalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                                        <TextBlock Text="Pesée Effectuée" FontFamily="Segoe UI"
                                                   FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#2ECC71"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WeighTime}" Value="{x:Null}">
                                                            <Setter Property="Foreground" Value="#C0C5D8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding WeighTimeDisplay}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="#8A8E9B"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Timeline step: Sortie -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="12" Height="12" CornerRadius="6"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top" Margin="0,3,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E4E8F0"/>
                                                <!-- default: grey -->
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExitTimeDisplay}" Value="--:--">
                                                        <Setter Property="Background" Value="#E4E8F0"/>
                                                        <!-- still grey when no exit -->
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Sorti">
                                                        <Setter Property="Background" Value="#1A1F3A"/>
                                                        <!-- dark only when Sorti -->
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Sortie Terminale" FontFamily="Segoe UI"
                                                   FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#9DA3C0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExitTime}" Value="{x:Null}">
                                                            <Setter Property="Foreground" Value="#C0C5D8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding ExitTimeDisplay}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="#8A8E9B"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Duration -->
                                <Border Background="#F8F9FF" CornerRadius="8"
                                        Padding="12,8" Margin="0,14,0,0"
                                        BorderBrush="#E4E8F0" BorderThickness="1">
                                    <Grid>
                                        <TextBlock Text="Durée totale" FontFamily="Segoe UI"
                                                   FontSize="11" Foreground="#8A8E9B"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DurationDisplay}"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>