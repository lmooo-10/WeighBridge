<UserControl x:Class="WeighBridge.Views.UserControls.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WeighBridge.Helpers">

    <UserControl.Resources>
        <uc:BarWidthConverter x:Key="BarWidthConverter"/>
    </UserControl.Resources>
    

    <Grid Background="{StaticResource ContentBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0 — Welcome card ═══ -->
        <Border Grid.Row="0" Background="White" Padding="20,14"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0"
                        Background="{Binding CurrentUser.RoleBadgeColor}">
                    <TextBlock Text="{Binding CurrentUser.Initials}"
           Foreground="Red" FontSize="16"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI" FontSize="18" FontWeight="Bold" Foreground="#1A1F3A">
                        <Run Text="Welcome back, "/>
                        <Run Text="{Binding CurrentUser.FullName}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Border CornerRadius="4" Padding="8,3" Margin="0,0,10,0"
                                Background="{Binding CurrentUser.RoleBadgeColor}">
                            <TextBlock Text="{Binding CurrentUser.RoleDisplayName}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="{Binding CurrentUser.StationInfo}"
                                   Foreground="#8A8E9B" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ ROW 1 — Live ticker ═══ -->
        <!-- LIVE ticker bar -->
        <Border Grid.Row="1" Height="36" Background="#1A1A2E" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/> <!--1120-->
                </Grid.ColumnDefinitions>

                <!-- LIVE badge -->
                <Border Grid.Column="0" Background="#E8001D">
                    <TextBlock Text="LIVE" FontSize="12" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Scrolling ticker -->
                <Grid Grid.Column="1" ClipToBounds="True">
                    <TextBlock x:Name="TickerText"
                       FontSize="13" Foreground="#E0E0E0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Text="{Binding TickerMessage}">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="TickerTranslate"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>

            </Grid>
        </Border>

        <!-- ═══ ROW 2 — Scrollable content ═══ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Hidden"
                      CanContentScroll="False">
            <StackPanel>

                <!-- ═══ Stats cards ═══ -->
                <UniformGrid Columns="4" Margin="20,16,20,0">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <StackPanel>

                            <!-- TODAY'S OPS -->
                            <TextBlock Text="{Binding TodaysOps}" Style="{StaticResource StatNumberStyle}" Margin="0,6,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TodaysDelta, StringFormat='+{0:F1}%'}" Foreground="#27AE60" />
                                <TextBlock Text=" vs yesterday" Foreground="#8A8E9B" FontSize="12" FontFamily="Segoe UI"/>
                            </StackPanel>
                            <ProgressBar Value="60" Maximum="100" Height="3" Background="#F0F2F8"
                                 Foreground="#E74C3C" Margin="0,10,0,0" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <!-- IMPORT -->
                            <TextBlock Text="{Binding ImportCount}" Style="{StaticResource StatNumberStyle}" Margin="0,6,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ImportDelta, StringFormat='+{0:F1}%'}" Foreground="#27AE60"/>
                                <TextBlock Text=" vs yesterday" Foreground="#8A8E9B" FontSize="12" FontFamily="Segoe UI"/>
                            </StackPanel>
                            <ProgressBar Value="38" Maximum="100" Height="3" Background="#F0F2F8"
                                 Foreground="#27AE60" Margin="0,10,0,0" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="GLOBAL PORTS" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="90" Style="{StaticResource StatNumberStyle}" Margin="0,6,0,4"/>
                            <TextBlock Text="41 countries" Style="{StaticResource CardLabelStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <!-- UPTIME -->
                            <TextBlock Text="{Binding Uptime, StringFormat='{}{0:F1}%'}" Style="{StaticResource StatNumberStyle}" Margin="0,6,0,4"/>
                            <TextBlock Text="System reliability" Style="{StaticResource CardLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ═══════════════════════════════════════════════════════════════
             CHARTS SECTION  (replaces old map/vessel area)
        ═══════════════════════════════════════════════════════════════ -->
                <Grid Margin="20,16,20,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══════════════════════════════
                 LEFT — Two stacked donut charts
                 ══════════════════════════════ -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ── DONUT 1 : Import vs Export ── -->
                        <Border Grid.Row="0" Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="4" CornerRadius="2" Background="#E8001D" Margin="0,0,8,0"/>
                                    <TextBlock Text="CONTENEURS PAR SENS" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#8A8E9B" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Arc ring: center=(75,75) r=60 stroke=22 -->
                                <!-- IMPORT 61% = 219.6° ≈ 220°
                             Start: top = (75, 15)
                             End at -90+220 = 130° → (75+60·cos130°, 75+60·sin130°)
                                                   = (75−38.57, 75+45.96) = (36.4, 120.96) -->
                                <!-- EXPORT 39% = 140° from (36.4,120.96) back to (75,15) -->
                                <Grid Width="150" Height="150" HorizontalAlignment="Center">

                                    <uc:DonutChart
                                        Value="{Binding ImportPct}"
                                        PrimaryColor="#E74C3C"
                                        SecondaryColor="#27AE60"
                                        ArcThickness="22"
                                        Width="150" Height="150"/>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TotalTEU, StringFormat='{}{0:N0}'}"
                   FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                   Foreground="#1A1F3A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Total TEU" FontFamily="Segoe UI" FontSize="10"
                   Foreground="#8A8E9B" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                </Grid>

                                <!-- Legend rows -->
                                <Grid Margin="0,10,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="10" Height="10" Fill="#E74C3C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Import" FontFamily="Segoe UI"
                                       FontSize="12" Foreground="#1A1F3A" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ImportTEU, StringFormat='{}{0} TEU '}" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#1A1F3A" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ImportPct, StringFormat='{}{0}%'}" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="10" Height="10" Fill="#27AE60" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Export" FontFamily="Segoe UI"
                                       FontSize="12" Foreground="#1A1F3A" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ExportTEU, StringFormat='{}{0} TEU '}" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#1A1F3A" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ExportPct, StringFormat='{}{0}%'}" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#27AE60" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── DONUT 2 : Container types ── -->
                        <!-- Segments (from top, clockwise):
                     20'Std  32% = 115.2° end=(129.4, 100.6)
                     40'Std  35% = 126°   end=(22.5,  103.9)
                     Reefer  18% = 64.8°  end=(26.4,   39.7)
                     Dang    15% = 54°    end=(75,       15)  ✓ -->
                        <Border Grid.Row="2" Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="4" CornerRadius="2" Background="#2D3561" Margin="0,0,8,0"/>
                                    <TextBlock Text="TYPES DE CONTENEURS" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#8A8E9B" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid Width="150" Height="150" HorizontalAlignment="Center">

                                    <uc:DonutChart4
                                       Value1="{Binding Std20Total}"
                                       Value2="{Binding Std40Total}"
                                       Value3="{Binding ReeferTotal}"
                                       Value4="{Binding DgrTotal}"
                                       Color1="#754dfe"
                                       Color2="#E8001D"
                                       Color3="#00B4D8"
                                       Color4="#ffbf4a"
                                       ArcThickness="22"
                                       Width="150" Height="150"/>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="4 types" FontFamily="Segoe UI" FontSize="14"
                                                   FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="conteneurs" FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="#8A8E9B" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                </Grid>

                                <UniformGrid Columns="2" Rows="2" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,3,4,3">
                                        <Rectangle Width="10" Height="10" Fill="#754dfe" RadiusX="2" RadiusY="2"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="20' Std" FontFamily="Segoe UI" FontSize="11" Foreground="#1A1F3A"/>
                                            <TextBlock Text="{Binding Std20Pct,  StringFormat='{}{0}%'}" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#754dfe"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <Rectangle Width="10" Height="10" Fill="#E8001D" RadiusX="2" RadiusY="2"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="40' Std" FontFamily="Segoe UI" FontSize="11" Foreground="#1A1F3A"/>
                                            <TextBlock Text="{Binding Std40Pct,  StringFormat='{}{0}%'}" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#E8001D"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,4,3">
                                        <Rectangle Width="10" Height="10" Fill="#00B4D8" RadiusX="2" RadiusY="2"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Réfrigéré" FontFamily="Segoe UI" FontSize="11" Foreground="#1A1F3A"/>
                                            <TextBlock Text="{Binding ReeferPct, StringFormat='{}{0}%'}" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#00B4D8"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <Rectangle Width="10" Height="10" Fill="#ffbf4a" RadiusX="2" RadiusY="2"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Mat. Dang." FontFamily="Segoe UI" FontSize="11" Foreground="#1A1F3A"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DgrPct, StringFormat='{}{0}%'}" 
                                                           FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#ffbf4a"/>
                                                <TextBlock Text=" (20')" 
                                                           FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#ffbf4a"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ═══════════════════════════════════════
                 RIGHT — Bar chart + summary cards
                 Bars use Grid star-columns for proportions:
                 filled col = value*, empty col = (436-value)*
                 (436 = max pair total: 40'Std import=256 + export=180)
                 ═══════════════════════════════════════ -->
                    <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header + legend -->
                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="4" CornerRadius="2" Background="#E8001D" Margin="0,0,8,0"/>
                                    <TextBlock Text="CONTENEURS PAR TYPE ET SENS" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Foreground="#8A8E9B"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Rectangle Width="12" Height="12" Fill="#E74C3C" RadiusX="2" RadiusY="2" Margin="0,0,5,0"/>
                                    <TextBlock Text="Import" FontFamily="Segoe UI" FontSize="11" Foreground="#8A8E9B" Margin="0,0,14,0"/>
                                    <Rectangle Width="12" Height="12" Fill="#27AE60" RadiusX="2" RadiusY="2" Margin="0,0,5,0"/>
                                    <TextBlock Text="Export" FontFamily="Segoe UI" FontSize="11" Foreground="#8A8E9B"/>
                                </StackPanel>
                            </Grid>

                            <!-- Bar groups -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- ── 20' Standard ── -->
                                <Grid Grid.Row="0" Margin="0,6,0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="10"/>
                                    </Grid.RowDefinitions>

                                    <!-- Label row -->
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <TextBlock Text="20' Standard" FontFamily="Segoe UI" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1A1F3A"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Std20Import, StringFormat='↑ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#E74C3C" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Std20Export, StringFormat='  ↓ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#27AE60" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Import bar -->
                                    <Grid Grid.Row="1">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#E74C3C"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="Std20Import"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>

                                    <!-- Export bar -->
                                    <Grid Grid.Row="3">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#27AE60"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="Std20Export"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- ── 40' Standard ── -->
                                <Grid Grid.Row="1" Margin="0,6,0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="10"/>
                                    </Grid.RowDefinitions>

                                    <!-- Label row -->
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <TextBlock Text="40' Standard" FontFamily="Segoe UI" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1A1F3A"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Std40Import, StringFormat='↑ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#fc539d" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Std40Export, StringFormat='  ↓ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#27AE60" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Import bar -->
                                    <Grid Grid.Row="1">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#E74C3C"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="Std40Import"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>

                                    <!-- Export bar -->
                                    <Grid Grid.Row="3">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#27AE60"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="Std40Export"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- ── Réfrigéré ── -->
                                <Grid Grid.Row="2" Margin="0,6,0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="10"/>
                                    </Grid.RowDefinitions>

                                    <!-- Label row -->
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <TextBlock Text="Reefer" FontFamily="Segoe UI" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1A1F3A"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding ReeferImport, StringFormat='↑ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#E74C3C" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding ReeferExport, StringFormat='  ↓ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#27AE60" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Import bar -->
                                    <Grid Grid.Row="1">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#E74C3C"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="ReeferImport"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>

                                    <!-- Export bar -->
                                    <Grid Grid.Row="3">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#27AE60"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="ReeferExport"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- ── Matières Dangereuses (20' only)  ↑165  ↓123 ── -->
                                <Grid Grid.Row="3" Margin="0,6,0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="10"/>
                                    </Grid.RowDefinitions>

                                    <!-- Label row -->
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <TextBlock Text="Matières Dangereuses" FontFamily="Segoe UI" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1A1F3A"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DgrImport, StringFormat='↑ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#E74C3C" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding DgrExport, StringFormat='  ↓ {0}'}"
                                                       FontFamily="Segoe UI" FontSize="11" Foreground="#27AE60" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Import bar -->
                                    <Grid Grid.Row="1">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#E74C3C"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="DgrImport"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>

                                    <!-- Export bar -->
                                    <Grid Grid.Row="3">
                                        <Border CornerRadius="3" Background="#F0F2F8"/>
                                        <Border CornerRadius="3" Background="#27AE60"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource BarWidthConverter}" ConverterParameter="450">
                                                    <Binding Path="DgrExport"/>
                                                    <Binding Path="MaxBarValue"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <!-- Divider -->
                            <Border Grid.Row="2" Background="{StaticResource BorderBrush}" Height="1" Margin="0,6,0,10"/>

                            <!-- Summary total cards -->
                            <UniformGrid Grid.Row="3" Columns="4">

                                <Border Margin="0,0,10,0" Background="#F8F9FF" CornerRadius="8" Padding="10,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Rectangle Width="10" Height="10" Fill="#754dfe" RadiusX="2" RadiusY="2"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="20' STD" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="Bold" Foreground="#8A8E9B"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Std20Total}" FontFamily="Segoe UI" FontSize="22" FontWeight="Bold" Foreground="#1A1F3A"/>
                                        <TextBlock Text="TEU total" FontFamily="Segoe UI" FontSize="10" Foreground="#8A8E9B"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
