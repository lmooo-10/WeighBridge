<UserControl x:Class="WeighBridge.Views.UserControls.NavBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource NavbarBgBrush}"
            BorderBrush="#0D1128" BorderThickness="0,0,0,1">
        <Grid Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Page title + date -->
                <ColumnDefinition Width="*"/>     <!-- Status indicators -->
                <ColumnDefinition Width="Auto"/>  <!-- Clock + user -->
            </Grid.ColumnDefinitions>

            <!-- Col 0 : Page title + current date -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding PageTitle}"
                           Foreground="White" FontFamily="Segoe UI"
                           FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" |" Foreground="#3A4060"
                           FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentDate}"
                           Foreground="#9DA3C0" FontFamily="Segoe UI"
                           FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Col 1 : Live status dots -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="WB-01 Online" Foreground="#9DA3C0"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse Width="8" Height="8" Fill="#2ECC71" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="Zodiac Connected" Foreground="#9DA3C0"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#E67E22" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="3 Vessels Inbound" Foreground="#9DA3C0"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Notification bell -->
                <Border Width="32" Height="32" CornerRadius="8"
                        Background="#252B50" Margin="20,0,0,0" Cursor="Hand">
                    <Grid>
                        <TextBlock Text="🔔" FontSize="14" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Border Width="14" Height="14" CornerRadius="7"
                                Background="#E8001D"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-2,-2,0">
                            <TextBlock Text="3" Foreground="White" FontSize="9"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Col 2 : Clock + user avatar -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center">

                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding CurrentTime}"
                               Foreground="White" FontFamily="Consolas"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentUser.FullName, Mode=OneWay}"
                               Foreground="#9DA3C0" FontFamily="Segoe UI"
                               FontSize="11" HorizontalAlignment="Right"/>
                </StackPanel>

                <!-- User avatar circle -->
                <Border Width="36" Height="36" CornerRadius="18"
                        Background="#E8001D">
                    <TextBlock Text="{Binding CurrentUser.Initials, Mode=OneWay}"
                               Foreground="White" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
