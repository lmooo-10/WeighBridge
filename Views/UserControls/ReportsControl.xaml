<UserControl x:Class="WeighBridge.Views.UserControls.ReportsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            >


    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{StaticResource ContentBgBrush}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Heading -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Reports &amp; Analytics" FontFamily="Segoe UI"
                           FontSize="26" FontWeight="Bold" Foreground="#1A1F3A"/>
                <TextBlock Text="Comprehensive weighbridge insights"
                           FontFamily="Segoe UI" FontSize="13" Foreground="#8A8E9B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Generate Report bar -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="⊟ Generate Report" FontFamily="Segoe UI"
                               FontSize="14" FontWeight="SemiBold" Foreground="#1A1F3A"
                               VerticalAlignment="Top" Margin="0,0,0,16"/>
                    <Grid Margin="0,32,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Report Type" Style="{StaticResource CardLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource DPComboBoxStyle}"
                                      ItemsSource="{Binding ReportTypes}"
                                      SelectedItem="{Binding ReportType}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Period" Style="{StaticResource CardLabelStyle}" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource DPComboBoxStyle}"
                                      ItemsSource="{Binding Periods}"
                                      SelectedItem="{Binding Period}"/>
                        </StackPanel>
                        <Button Grid.Column="4" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding DownloadReportCommand}"
                                VerticalAlignment="Bottom" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↓ " FontSize="13"/>
                                <TextBlock Text="Download Report" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Stats cards row -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
                <Border Margin="0,0,12,0" CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3"
                        BorderBrush="#2D3561">
                    <StackPanel>
                        <TextBlock Text="Total Weighments" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TotalWeighments}" FontFamily="Segoe UI"
                                   FontSize="36" FontWeight="Bold" Foreground="#1A1F3A"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Completed operations" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3"
                        BorderBrush="#2ECC71">
                    <StackPanel>
                        <TextBlock Text="Total Weight" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TotalWeight}" FontFamily="Segoe UI"
                                   FontSize="36" FontWeight="Bold" Foreground="#1A1F3A"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Processed cargo" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3"
                        BorderBrush="#2ECC71">
                    <StackPanel>
                        <TextBlock Text="Average Weight" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding AverageWeight}" FontFamily="Segoe UI"
                                   FontSize="36" FontWeight="Bold" Foreground="#1A1F3A"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Per weighment" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3"
                        BorderBrush="#E67E22">
                    <StackPanel>
                        <TextBlock Text="Pending" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding Pending}" FontFamily="Segoe UI"
                                   FontSize="36" FontWeight="Bold" Foreground="#1A1F3A"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Incomplete weighments" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts placeholder row -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Inbound/Outbound distribution -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" MinHeight="280">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="⊞ " Foreground="#1A1F3A" FontSize="14"/>
                            <TextBlock Text="Weighment Type Distribution"
                                       FontFamily="Segoe UI" FontSize="14"
                                       FontWeight="SemiBold" Foreground="#1A1F3A"/>
                        </StackPanel>
                        <!-- Simple bar visualisation -->
                        <StackPanel Margin="0,10,0,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Import" FontSize="12" Foreground="#E74C3C"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Height="22" CornerRadius="4"
                                        Background="#E74C3C" HorizontalAlignment="Left"
                                        Width="200"/>
                                <TextBlock Grid.Column="2" Text="2" FontSize="12"
                                           FontWeight="Bold" Foreground="#E74C3C"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Export" FontSize="12" Foreground="#27AE60"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Height="22" CornerRadius="4"
                                        Background="#27AE60" HorizontalAlignment="Left"
                                        Width="200"/>
                                <TextBlock Grid.Column="2" Text="2" FontSize="12"
                                           FontWeight="Bold" Foreground="#27AE60"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Top materials -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" MinHeight="280">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="↗ " Foreground="#1A1F3A" FontSize="14"/>
                            <TextBlock Text="Top Materials by Weight"
                                       FontFamily="Segoe UI" FontSize="14"
                                       FontWeight="SemiBold" Foreground="#1A1F3A"/>
                        </StackPanel>
                        <ItemsControl>
                            <ItemsControl.Items>
                                <StackPanel Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock Text="Construction Materials" FontSize="12" Foreground="#8A8E9B"/>
                                        <Border HorizontalAlignment="Left" Height="12" Width="220"
                                                Background="#1A1F3A" CornerRadius="3" Margin="0,20,0,0"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Steel Coils" FontSize="12" Foreground="#8A8E9B"/>
                                    <Border HorizontalAlignment="Left" Height="12" Width="185"
                                            Background="#1A1F3A" CornerRadius="3" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Automotive Parts" FontSize="12" Foreground="#8A8E9B"/>
                                    <Border HorizontalAlignment="Left" Height="12" Width="170"
                                            Background="#1A1F3A" CornerRadius="3" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Textiles" FontSize="12" Foreground="#8A8E9B"/>
                                    <Border HorizontalAlignment="Left" Height="12" Width="120"
                                            Background="#1A1F3A" CornerRadius="3" Margin="0,4,0,0"/>
                                </StackPanel>
                            </ItemsControl.Items>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
