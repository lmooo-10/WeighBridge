<UserControl x:Class="WeighBridge.Views.UserControls.ReportsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WeighBridge.Helpers">

    <UserControl.Resources>
        <uc:BarWidthConverter x:Key="BarWidthConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Grid Background="{StaticResource ContentBgBrush}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0 Heading -->
                <RowDefinition Height="Auto"/>
                <!-- 1 Filters bar -->
                <RowDefinition Height="Auto"/>
                <!-- 2 KPI cards -->
                <RowDefinition Height="Auto"/>
                <!-- 3 Shift summary + Type distribution -->
                <RowDefinition Height="Auto"/>
                <!-- 4 Weighment ticket table -->
            </Grid.RowDefinitions>

            <!-- ══ ROW 0 — Heading ══ -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Reports &amp; Analytics" FontFamily="Segoe UI"
                               FontSize="26" FontWeight="Bold" Foreground="#1A1F3A"/>
                    <TextBlock Text="Formal weighbridge records — filter, verify and export"
                               FontFamily="Segoe UI" FontSize="13" Foreground="#8A8E9B"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Action buttons top-right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ExportCsvCommand}"
                            Padding="14,10" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↓ " FontSize="13"/>
                            <TextBlock Text="Export CSV" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding DownloadReportCommand}"
                            Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊟ " FontSize="13"/>
                            <TextBlock Text="Download Report" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ══ ROW 1 — Filters bar ══ -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SEARCH" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Style="{StaticResource DPTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Report Type -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="REPORT TYPE" Style="{StaticResource InputLabelStyle}"/>
                        <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5"  Margin="0,4,0,0" Background="Transparent">
                            <ComboBox ItemsSource="{Binding ReportTypes}"
                  SelectedItem="{Binding ReportType}"
                  Foreground="#1A1F3A"
                  FontFamily="Segoe UI"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4,6"/>
                        </Border>
                    </StackPanel>

                    <!-- Period -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="PERIOD" Style="{StaticResource InputLabelStyle}"/>
                        <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5"  Margin="0,4,0,0" Background="Transparent">
                            <ComboBox ItemsSource="{Binding Periods}"
                  SelectedItem="{Binding Period}"
                  Foreground="#1A1F3A"
                  FontFamily="Segoe UI"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4,6"/>
                        </Border>
                    </StackPanel>

                    <!-- Status -->
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="STATUS" Style="{StaticResource InputLabelStyle}"/>
                        <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5"  Margin="0,4,0,0" Background="Transparent">
                            <ComboBox ItemsSource="{Binding StatusFilters}"
                  SelectedItem="{Binding StatusFilter}"
                  Foreground="#1A1F3A"
                  FontFamily="Segoe UI"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4,6"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ ROW 2 — KPI Cards ══ -->
            <UniformGrid Grid.Row="2" Columns="6" Margin="0,0,0,20">

                <!-- Total -->
                <Border Margin="0,0,10,0" CornerRadius="10" Padding="16,14"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#1A1F3A">
                    <StackPanel>
                        <TextBlock Text="TOTAL" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TotalWeighments}" FontFamily="Segoe UI"
                                   FontSize="30" FontWeight="Bold" Foreground="#1A1F3A"
                                   Margin="0,6,0,2"/>
                        <TextBlock Text="Weighments" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Completed -->
                <Border Margin="0,0,10,0" CornerRadius="10" Padding="16,14"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#3B6D11">
                    <StackPanel>
                        <TextBlock Text="COMPLETED" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding CompletedCount}" FontFamily="Segoe UI"
                                   FontSize="30" FontWeight="Bold" Foreground="#3B6D11"
                                   Margin="0,6,0,2"/>
                        <TextBlock Text="Operations" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Pending -->
                <Border Margin="0,0,10,0" CornerRadius="10" Padding="16,14"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#EF9F27">
                    <StackPanel>
                        <TextBlock Text="PENDING" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding PendingCount}" FontFamily="Segoe UI"
                                   FontSize="30" FontWeight="Bold" Foreground="#EF9F27"
                                   Margin="0,6,0,2"/>
                        <TextBlock Text="Incomplete" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Total Net Weight -->
                <Border Margin="0,0,10,0" CornerRadius="10" Padding="16,14"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#2D3561">
                    <StackPanel>
                        <TextBlock Text="NET WEIGHT" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TotalNetWeight, StringFormat='{}{0:F2}'}"
                                   FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="#1A1F3A" Margin="0,6,0,2"/>
                        <TextBlock Text="Total cargo" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Average Net Weight -->
                <Border Margin="0,0,10,0" CornerRadius="10" Padding="16,14"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#2D3561">
                    <StackPanel>
                        <TextBlock Text="AVG NET" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding AverageNetWeight, StringFormat='{}{0:F2}'}"
                                   FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="#1A1F3A" Margin="0,6,0,2"/>
                        <TextBlock Text="Per weighment" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Import vs Export mini -->
                <Border CornerRadius="10" Padding="16,14"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#E74C3C">
                    <StackPanel>
                        <TextBlock Text="Import / Export" Style="{StaticResource CardLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,2">
                            <TextBlock Text="{Binding ImportCount}" FontFamily="Segoe UI"
                                       FontSize="24" FontWeight="Bold" Foreground="#E74C3C"/>
                            <TextBlock Text=" / " FontFamily="Segoe UI"
                                       FontSize="24" FontWeight="Bold" Foreground="#8A8E9B"/>
                            <TextBlock Text="{Binding ExportCount}" FontFamily="Segoe UI"
                                       FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══ ROW 3 — Shift Summary + Type Distribution ══ -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Shift Summary table -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="4" CornerRadius="2" Background="#E8001D" Margin="0,0,10,0"/>
                            <TextBlock Text="SHIFT SUMMARY" FontFamily="Segoe UI"
                                       FontSize="13" FontWeight="Bold" Foreground="#1A1F3A"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Column headers -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SHIFT"
                                       Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="OPERATOR"
                                       Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Grid.Column="2" Text="OPS"
                                       Style="{StaticResource CardLabelStyle}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="TOTAL WEIGHT"
                                       Style="{StaticResource CardLabelStyle}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="HOURS"
                                       Style="{StaticResource CardLabelStyle}"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                        <!-- Shift rows -->
                        <ItemsControl ItemsSource="{Binding ShiftSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Shift badge -->
                                        <Border Grid.Column="0" CornerRadius="10" Padding="10,4"
        HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ShiftName}"
                   FontSize="11" FontWeight="SemiBold"
                   FontFamily="Segoe UI"
                   VerticalAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding ShiftColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Operator}"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="#1A1F3A"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding OpsCount}"
                                                   FontFamily="Segoe UI" FontSize="14"
                                                   FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TotalWeight, StringFormat='{}{0:F1}'}"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#2D3561"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4"
                                                   FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="#8A8E9B"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding StartTime}"/>
                                            <Run Text=" – "/>
                                            <Run Text="{Binding EndTime}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Type Distribution bars -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="4" CornerRadius="2" Background="#E8001D" Margin="0,0,10,0"/>
                            <TextBlock Text="TYPE DISTRIBUTION" FontFamily="Segoe UI"
                                       FontSize="13" FontWeight="Bold" Foreground="#1A1F3A"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Import bar -->
                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Import" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#E74C3C"/>
                                <TextBlock Text="{Binding ImportCount}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#E74C3C"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Height="18">
                                <Border CornerRadius="4" Background="#F0F2F8"/>
                                <Border CornerRadius="4" Background="#E74C3C"
                                        HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource BarWidthConverter}"
                                                      ConverterParameter="260">
                                            <Binding Path="ImportCount"/>
                                            <Binding Path="MaxTypeValue"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Export bar -->
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Export" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#27AE60"/>
                                <TextBlock Text="{Binding ExportCount}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#27AE60"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Height="18">
                                <Border CornerRadius="4" Background="#F0F2F8"/>
                                <Border CornerRadius="4" Background="#27AE60"
                                        HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource BarWidthConverter}"
                                                      ConverterParameter="260">
                                            <Binding Path="ExportCount"/>
                                            <Binding Path="MaxTypeValue"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ ROW 4 — Weighment Ticket Table ══ -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table header -->
                    <Grid Grid.Row="0" Margin="20,14,20,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" CornerRadius="2" Background="#E8001D" Margin="0,0,10,0"/>
                            <TextBlock Text="WEIGHBRIDGE TICKETS" FontFamily="Segoe UI"
                                       FontSize="13" FontWeight="Bold" Foreground="#1A1F3A"
                                       VerticalAlignment="Center"/>
                            <Border CornerRadius="10" Background="#F0F2F8"
                                    Padding="8,3" Margin="12,0,0,0">
                                <TextBlock Text="{Binding FilteredRows.Count, StringFormat='{}{0} records'}"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#8A8E9B"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Separator Grid.Row="1" Background="{StaticResource BorderBrush}"/>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FilteredRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeight="46"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              Background="White"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              CanUserResizeColumns="True">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#1A1F3A"/>
                                <Setter Property="Foreground"      Value="White"/>
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize"   Value="13"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F7FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- Ticket # -->
                            <DataGridTextColumn Header="Ticket #"
                                                Binding="{Binding TicketNumber}"
                                                Width="120"/>

                            <!-- Date/Time -->
                            <DataGridTextColumn Header="Date / Time"
                                                Binding="{Binding Date, StringFormat='dd MMM yyyy  HH:mm'}"
                                                Width="155"/>

                            <!-- Vehicle -->
                            <DataGridTextColumn Header="Vehicle"
                                                Binding="{Binding VehicleNumber}"
                                                Width="115"/>

                            <!-- Driver -->
                            <DataGridTextColumn Header="Driver"
                                                Binding="{Binding DriverName}"
                                                Width="130"/>

                            <!-- Container -->
                            <DataGridTextColumn Header="Container #"
                                                Binding="{Binding ContainerNumber}"
                                                Width="115"/>

                            <!-- Material -->
                            <DataGridTextColumn Header="Material"
                                                Binding="{Binding Material}"
                                                Width="140"/>

                            <!-- Gross -->
                            <DataGridTextColumn Header="Gross"
                                                Binding="{Binding GrossWeight, StringFormat='{}{0:F2}'}"
                                                Width="85"/>

                            <!-- Tare -->
                            <DataGridTextColumn Header="Tare"
                                                Binding="{Binding TareWeight, StringFormat='{}{0:F2}'}"
                                                Width="80"/>

                            <!-- Net -->
                            <DataGridTextColumn Header="Net"
                                                Binding="{Binding NetWeight, StringFormat='{}{0:F2}'}"
                                                Width="80"/>

                            <!-- Type -->
                            <DataGridTemplateColumn Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,3,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="↓"/>
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Export">
                                                                <Setter Property="Text"       Value="↑"/>
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Type}" FontFamily="Segoe UI" FontSize="11"
                                                               VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Export">
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Status -->
                            <!-- Status -->
                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20" Padding="10,4"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding StatusBgColor}"/>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding StatusBadgeColor}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}"
                               FontSize="11" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding StatusBadgeColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Operator -->
                            <DataGridTextColumn Header="Operator"
                                                Binding="{Binding Operator}"
                                                Width="120"/>

                            <!-- Shift -->
                            <DataGridTextColumn Header="Shift"
                                                Binding="{Binding Shift}"
                                                Width="90"/>

                            <!-- Print button -->
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🖨"
                                                FontSize="14"
                                                ToolTip="Print ticket"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.PrintTicketCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>

