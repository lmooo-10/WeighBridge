<UserControl x:Class="WeighBridge.Views.UserControls.SideBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource SidebarBgBrush}">
        <DockPanel>

            <!-- Role badge -->
            <Border DockPanel.Dock="Top" Margin="12,12,12,4"
                    CornerRadius="5" Padding="10,5" Background="#1E2448">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding CurrentUser.RoleBadgeColor}"
                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="{Binding CurrentUser.RoleDisplayName, Mode=OneWay}"
                               Foreground="{Binding CurrentUser.RoleBadgeColor, Mode=OneWay}"
                               FontSize="11" FontWeight="SemiBold"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Bottom: user info + logout -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="#1E2448" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="34" Height="34"
                            CornerRadius="17"
                            Background="{Binding CurrentUser.RoleBadgeColor}"
                            Margin="0,0,10,0">
                        <TextBlock Text="{Binding CurrentUser.Initials, Mode=OneWay}"
                                   Foreground="White" FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUser.FullName, Mode=OneWay}"
                                   Foreground="White" FontSize="12"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <TextBlock Foreground="#4A5080" FontSize="10" FontFamily="Segoe UI">
                            <Run Text="{Binding CurrentUser.WeighbridgeId}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding CurrentUser.RoleDisplayName, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Style="{StaticResource SideMenuButtonStyle}"
                            Padding="8" ToolTip="Logout"
                            Command="{Binding LogoutCommand}">
                        <TextBlock Text="⇥" Foreground="#9DA3C0" FontSize="16"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Shift indicator -->
            <Border DockPanel.Dock="Bottom" Margin="12,0,12,4"
                    CornerRadius="5" Padding="10,6" Background="#0D1128">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding CurrentUser.RoleBadgeColor}"
                             Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentUser.ShiftDisplayName, Mode=OneWay}"
                               Foreground="#4A5080" FontSize="10"
                               FontFamily="Segoe UI" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Navigation menu -->
            <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="0,6,0,0">

                    <!-- OPERATIONS -->
                    <TextBlock Text="OPERATIONS" Style="{StaticResource SideCategoryStyle}"/>

                    <!-- Dashboard — ALL roles -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="dashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="dashboard">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="20" Foreground="Black"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Global Dashboard"
                                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- Weighing Console — Admin + Agent only -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="console"
                            Visibility="{Binding ShowConsole}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="console">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Image  Source="/Assets/Images/weight-icon.png" Width="16"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Weighing Console"
                                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- Weighment History — ALL roles -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="history">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="history">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/history-icon.png" Width="16"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Weighment History"
                                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- Container Tracking — Admin + Agent only -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="containers"
            Visibility="{Binding ShowConsole}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="containers">
                                        <Setter Property="Background"     Value="#252B50"/>
                                        <Setter Property="BorderBrush"    Value="#E8001D"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊡" FontSize="16" Foreground="#9DA3C0"
                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Suivi Conteneurs"
                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- Reports — Admin + Commercial only -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="reports"
                            Visibility="{Binding ShowReports}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="reports">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/report-icon.png" Width="18"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reports"
                                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- VGM Management — Admin + Agent only -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="vgm"
                            Visibility="{Binding ShowVGM}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="vgm">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/notes-icon.png" Width="20"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="VGM Management"
                                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- NETWORK -->
                    <TextBlock Text="NETWORK" Style="{StaticResource SideCategoryStyle}"/>

                    <!-- Exports — Admin + Commercial only -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="exports"
                            Visibility="{Binding ShowExports}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="exports">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↓" FontSize="16" Foreground="#9DA3C0"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Exports"
                                       Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <!-- Terminal Network — Admin only (SOON) -->
                    <Button Style="{StaticResource SideMenuButtonStyle}"
                            IsEnabled="False"
                            Visibility="{Binding ShowTerminalNetwork}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌐" FontSize="14" Foreground="Black"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Terminal Network" Foreground="#3A4060"
                                       FontSize="13" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Border CornerRadius="3" Background="#1E2448"
                                    Padding="5,2" Margin="8,0,0,0">
                                <TextBlock Text="SOON" Foreground="#4A5080"
                                           FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Vessel Schedule — ALL roles (SOON) -->
                    <Button Style="{StaticResource SideMenuButtonStyle}" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚢" FontSize="14" Foreground="Black"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Vessel Schedule" Foreground="#3A4060"
                                       FontSize="13" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Border CornerRadius="3" Background="#1E2448"
                                    Padding="5,2" Margin="8,0,0,0">
                                <TextBlock Text="SOON" Foreground="#4A5080"
                                           FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    

                    <!-- SYSTEM — Admin only -->
                    <TextBlock Text="SYSTEM" Style="{StaticResource SideCategoryStyle}"
           Visibility="{Binding ShowSettings}"/>

                    <!-- User Management — replaces the old disabled Settings button -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="settings"
        Visibility="{Binding ShowSettings}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveMenu}" Value="settings">
                                        <Setter Property="Background"      Value="#252B50"/>
                                        <Setter Property="BorderBrush"     Value="#E8001D"/>
                                        <Setter Property="BorderThickness"  Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7EE;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                   Foreground="#9DA3C0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="User Management"
                   Style="{StaticResource SideMenuTextStyle}"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
