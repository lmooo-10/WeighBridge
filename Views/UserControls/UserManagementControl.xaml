<UserControl x:Class="WeighBridge.Views.UserControls.UserManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F7">

    <UserControl.Resources>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="Navy"       Color="#1A1F3A"/>
        <SolidColorBrush x:Key="NavyLight"  Color="#252B50"/>
        <SolidColorBrush x:Key="Red"        Color="#E8001D"/>
        <SolidColorBrush x:Key="Gold"       Color="#C9A84C"/>
        <SolidColorBrush x:Key="Green"      Color="#2ECC71"/>
        <SolidColorBrush x:Key="PageBg"     Color="#F0F2F7"/>
        <SolidColorBrush x:Key="CardBg"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderCol"  Color="#E4E8F0"/>
        <SolidColorBrush x:Key="TextMain"   Color="#1A1F3A"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#8A8E9B"/>

        <!-- ── White card ── -->
        <Style x:Key="WhiteCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                      Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stat card ── -->
        <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource WhiteCard}">
            <Setter Property="Padding" Value="20,16"/>
        </Style>

        <!-- ── Section label ── -->
        <Style x:Key="SectionLbl" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <!-- ── Field label ── -->
        <Style x:Key="FormLbl" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <!-- ── Light TextBox ── -->
        <Style x:Key="LightField" TargetType="TextBox">
            <Setter Property="Height"                   Value="38"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="{StaticResource TextMain}"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#1A1F3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Light PasswordBox ── -->
        <Style x:Key="LightPassword" TargetType="PasswordBox">
            <Setter Property="Height"                   Value="38"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="{StaticResource TextMain}"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness"          Value="1"/>
        </Style>

        <!-- ── Primary button (red) ── -->
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background"      Value="#E8001D"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0001A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost button ── -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="#EEF0F6"/>
            <Setter Property="Foreground"      Value="#1A1F3A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDE0EC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════
         ROOT GRID : left list | right form
    ══════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════  LEFT PANEL  ══════════════ -->
        <Grid Grid.Column="0" Margin="24,24,12,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Page header    -->
                <RowDefinition Height="16"/>
                <!-- spacer         -->
                <RowDefinition Height="Auto"/>
                <!-- KPI cards      -->
                <RowDefinition Height="16"/>
                <!-- spacer         -->
                <RowDefinition Height="Auto"/>
                <!-- Toolbar        -->
                <RowDefinition Height="12"/>
                <!-- spacer         -->
                <RowDefinition Height="*"/>
                <!-- Table          -->
                <RowDefinition Height="Auto"/>
                <!-- Status message -->
            </Grid.RowDefinitions>

            <!-- ── Page header ── -->
            <Grid Grid.Row="0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="User Management"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextMain}"/>
                    <TextBlock Text="Manage operator accounts, roles and access permissions"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ── KPI cards ── -->
            <UniformGrid Grid.Row="2" Columns="3">

                <!-- Total -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0"
                        BorderThickness="0,0,0,3" BorderBrush="{StaticResource Navy}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource Navy}"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="TOTAL USERS" Style="{StaticResource SectionLbl}" Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Users.Count}"
                                   FontFamily="Segoe UI" FontSize="34" FontWeight="ExtraBold"
                                   Foreground="{StaticResource Navy}"/>
                        <TextBlock Text="Registered accounts" Style="{StaticResource SectionLbl}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Active -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0"
                        BorderThickness="0,0,0,3" BorderBrush="{StaticResource Green}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource Green}"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ACTIVE" Style="{StaticResource SectionLbl}" Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveCount}"
                                   FontFamily="Segoe UI" FontSize="34" FontWeight="ExtraBold"
                                   Foreground="{StaticResource Green}"/>
                        <TextBlock Text="Enabled logins" Style="{StaticResource SectionLbl}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Admins -->
                <Border Style="{StaticResource StatCard}"
                        BorderThickness="0,0,0,3" BorderBrush="{StaticResource Red}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource Red}"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ADMINS" Style="{StaticResource SectionLbl}" Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AdminCount}"
                                   FontFamily="Segoe UI" FontSize="34" FontWeight="ExtraBold"
                                   Foreground="{StaticResource Red}"/>
                        <TextBlock Text="Full-access roles" Style="{StaticResource SectionLbl}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- ── Toolbar ── -->
            <Border Grid.Row="4" Style="{StaticResource WhiteCard}" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource BtnRed}"
                            Command="{Binding NewUserCommand}"
                            Padding="16,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="NEW USER" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnGhost}"
                            Command="{Binding DeactivateCommand}"
                            Padding="14,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏸ " FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="DEACTIVATE" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BtnGhost}"
                            Command="{Binding ResetPasswordCommand}"
                            Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔑 " FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="RESET PASSWORD" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ── Table ── -->
            <Border Grid.Row="6" Style="{StaticResource WhiteCard}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table header bar -->
                    <Border Grid.Row="0" Background="#1A1F3A"
                            CornerRadius="12,12,0,0" Padding="0,0,0,0">
                        <Grid Margin="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="OPERATOR ID" HorizontalAlignment="Center"
                                       Foreground="White" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Padding="20,12"/>
                            <TextBlock Grid.Column="1" Text="FULL NAME" HorizontalAlignment="Center"
                                       Foreground="White" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Padding="8,12"/>
                            <TextBlock Grid.Column="2" Text="ROLE" HorizontalAlignment="Center"
                                       Foreground="White" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Padding="8,12"/>
                            <TextBlock Grid.Column="3" Text="STATUS" HorizontalAlignment="Center"
                                       Foreground="White" FontFamily="Segoe UI"
                                       FontSize="11" FontWeight="Bold" Padding="8,12"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid rows -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="None"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F2F8"
                              VerticalScrollBarVisibility="Hidden"
                              Background="White"
                              BorderThickness="0"
                              RowHeight="52"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              SelectionMode="Single">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="FontSize"        Value="13"/>
                                <Setter Property="Background"      Value="White"/>
                                <Setter Property="Foreground"      Value="#1A1F3A"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F7FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EEF0FF"/>
                                        <Setter Property="Foreground" Value="#1A1F3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness"  Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="Transparent" Padding="4,0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <!-- Operator ID -->
                            <DataGridTemplateColumn Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                            <!-- Avatar circle -->
                                            <Border Width="32" Height="32" CornerRadius="16"
                                                    Background="#EEF0FF" Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Initials}"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           FontWeight="Bold" Foreground="#1A1F3A"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding OperatorId}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="#1A1F3A"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Full Name -->
                            <DataGridTemplateColumn Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                           FontFamily="Segoe UI" FontSize="13"
                           FontWeight="SemiBold" Foreground="#1A1F3A"
                           HorizontalAlignment="Center"/>
                                            <!-- ← was Center -->
                                            <TextBlock Text="{Binding ShiftDisplayName}"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#8A8E9B" Margin="0,2,0,0"
                           HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Role badge -->
                            <DataGridTemplateColumn Width="300">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20" Padding="12,4"
                                                HorizontalAlignment="Center" Margin="8,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FDF6E3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                            <Setter Property="Background" Value="#FFF0F0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="Commercial">
                                                            <Setter Property="Background" Value="#EDFAF3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6"
                                                         VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#C9A84C"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                                    <Setter Property="Fill" Value="#E8001D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Role}" Value="Commercial">
                                                                    <Setter Property="Fill" Value="#2ECC71"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding RoleDisplayName}"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#C9A84C"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                                    <Setter Property="Foreground" Value="#E8001D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Role}" Value="Commercial">
                                                                    <Setter Property="Foreground" Value="#2ECC71"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Status -->
                            <DataGridTemplateColumn Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                                            <Ellipse Width="8" Height="8"
                                                     VerticalAlignment="Center" Margin="0,0,7,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#45A366"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Fill" Value="#84858D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock FontFamily="Segoe UI" FontSize="12"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"> 
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="Online"/>
                                                        <Setter Property="Foreground" Value="#45A366"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text"       Value="Offline"/>
                                                                <Setter Property="Foreground" Value="#84858D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── Status message ── -->
            <Border Grid.Row="7"
                    Visibility="{Binding HasMessage,
                        Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="0,10,0,0">
                <Border Background="#EDFAF3" CornerRadius="8" Padding="14,9">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#2ECC71"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Message}"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>

        <!-- ══════════════  RIGHT PANEL — Form  ══════════════ -->
        <Border Grid.Column="1" Margin="12,24,24,24"
                Visibility="{Binding IsFormVisible,
                    Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Style="{StaticResource WhiteCard}" Padding="0">
                <DockPanel>

                    <!-- Form header strip -->
                    <Border DockPanel.Dock="Top"
                            Background="#1A1F3A"
                            CornerRadius="12,12,0,0"
                            Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="CREATE / EDIT USER"
                                       FontFamily="Segoe UI" FontSize="14"
                                       FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Fill in the operator details below"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#6A7098" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Form body -->
                    <ScrollViewer DockPanel.Dock="Top"
                                  VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="24,24,24,8">

                            <!-- Operator ID -->
                            <TextBlock Text="OPERATOR ID" Style="{StaticResource FormLbl}"/>
                            <TextBox Style="{StaticResource LightField}"
                                     Text="{Binding FormOperatorId, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,16"/>

                            <!-- Full Name -->
                            <TextBlock Text="FULL NAME" Style="{StaticResource FormLbl}"/>
                            <TextBox Style="{StaticResource LightField}"
                                     Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,16"/>

                            <!-- Password -->
                            <TextBlock Text="PASSWORD" Style="{StaticResource FormLbl}"/>
                            <PasswordBox x:Name="PbPassword"
                                         Style="{StaticResource LightPassword}"
                                         Margin="0,0,0,16"/>

                            <!-- Role -->
                            <TextBlock Text="ROLE" Style="{StaticResource FormLbl}"/>
                            <Border BorderBrush="{StaticResource BorderCol}"
                                    BorderThickness="1" CornerRadius="4"
                                    Margin="0,0,0,16">
                                <ComboBox Style="{StaticResource ComboRole}"
                                    ItemsSource="{Binding Roles}"
                                          SelectedItem="{Binding FormRole}"/>
                            </Border>

                            <!-- Active toggle -->
                            <Border Background="#F8F9FF" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderCol}"
                                    BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding FormIsActive}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Active Account"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMain}"/>
                                        <TextBlock Text="User can log in to the system"
                                                   FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Save button -->
                            <Button Style="{StaticResource BtnRed}"
                                    Command="{Binding SaveUserCommand}"
                                    Height="44" Padding="0">
                                <TextBlock Text="SAVE USER"
                                           FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="Bold"/>
                            </Button>

                            <!-- Divider + extra actions -->
                            <Border Height="1" Background="{StaticResource BorderCol}" Margin="0,20,0,16"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource BtnGhost}"
                                        Command="{Binding DeactivateCommand}"
                                        Padding="14,8" Margin="0,0,8,0">
                                    <TextBlock Text="Toggle Active" FontSize="11"/>
                                </Button>
                                <Button Style="{StaticResource BtnGhost}"
                                        Command="{Binding ResetPasswordCommand}"
                                        Padding="14,8">
                                    <TextBlock Text="Reset Password" FontSize="11"/>
                                </Button>
                            </StackPanel>

                            <TextBlock Margin="0,20,0,8"/>
                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
