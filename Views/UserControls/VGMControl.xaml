<UserControl x:Class="WeighBridge.Views.UserControls.VGMControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            >


    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{StaticResource ContentBgBrush}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Heading -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="VGM (Verified Gross Mass)" FontFamily="Segoe UI"
                               FontSize="26" FontWeight="Bold" Foreground="#1A1F3A"/>
                    <TextBlock Text="SOLAS container weight verification"
                               FontFamily="Segoe UI" FontSize="13" Foreground="#8A8E9B" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding IssueCertificateCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊟ " FontSize="13"/>
                        <TextBlock Text="Issue VGM Certificate" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Stats cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                <Border Margin="0,0,12,0" CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#2D3561">
                    <StackPanel>
                        <TextBlock Text="Total VGM Issued" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TotalVGMIssued}" Style="{StaticResource StatNumberStyle}"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Certificates" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#2ECC71">
                    <StackPanel>
                        <TextBlock Text="Today's VGM" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding TodaysVGM}" Style="{StaticResource StatNumberStyle}"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Issued today" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#2ECC71">
                    <StackPanel>
                        <TextBlock Text="Method 1" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding Method1Count}" Style="{StaticResource StatNumberStyle}"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Weighbridge method" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="10" Padding="20"
                        Background="White" BorderThickness="0,0,0,3" BorderBrush="#E67E22">
                    <StackPanel>
                        <TextBlock Text="Method 2" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding Method2Count}" Style="{StaticResource StatNumberStyle}"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Calculation method" Style="{StaticResource CardLabelStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- VGM Certificates DataGrid -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,14,20,14">
                        <TextBlock Text="VGM Certificates" FontFamily="Segoe UI"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#1A1F3A"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource DPTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 HorizontalAlignment="Right" Width="220"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Grid.Row="1" Background="{StaticResource BorderBrush}"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FilteredCertificates}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True" RowHeight="46"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              Background="White" BorderThickness="0"
                              HeadersVisibility="Column">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1A1F3A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize"   Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding"    Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Container #"   Binding="{Binding ContainerNumber}" Width="130"/>
                            <DataGridTextColumn Header="VGM Weight"    Binding="{Binding VGMWeight, StringFormat='{}{0:F2} MT'}" Width="110"/>
                            <DataGridTextColumn Header="Method"        Binding="{Binding Method}"          Width="90"/>
                            <DataGridTextColumn Header="Seal Number"   Binding="{Binding SealNumber}"      Width="110"/>
                            <DataGridTextColumn Header="Shipping Line" Binding="{Binding ShippingLine}"    Width="130"/>
                            <DataGridTextColumn Header="Booking #"     Binding="{Binding BookingNumber}"   Width="120"/>
                            <DataGridTextColumn Header="Verified By"   Binding="{Binding VerifiedBy}"      Width="130"/>
                            <DataGridTextColumn Header="Date"          Binding="{Binding Date, StringFormat='dd MMM yyyy, HH:mm'}" Width="160"/>
                            <DataGridTextColumn Header="Status"        Binding="{Binding Status}"          Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
