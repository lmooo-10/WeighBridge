<UserControl x:Class="WeighBridge.Views.UserControls.WeighingConsoleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            >


    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{StaticResource ContentBgBrush}" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Page heading -->
                <RowDefinition Height="*"/>     <!-- Main content -->
            </Grid.RowDefinitions>

            <!-- ── Page heading ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Weighing Console" FontFamily="Segoe UI"
                           FontSize="26" FontWeight="Bold" Foreground="#1A1F3A"/>
                <TextBlock Text="Live weighbridge operations" FontFamily="Segoe UI"
                           FontSize="13" Foreground="#8A8E9B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ── Two-column layout ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: Live Weight Panel ── -->
                <Border Grid.Column="0" Style="{StaticResource DarkCardStyle}">
                    <StackPanel>
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="⟳ " Foreground="White" FontSize="16"/>
                            <TextBlock Text="Live Weight Display" Foreground="White"
                                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Current Weight -->
                        <TextBlock Text="Current Weight" Foreground="#9DA3C0"
                                   FontFamily="Segoe UI" FontSize="12"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LiveWeight, StringFormat='{}{0:F2}'}"
                                   Foreground="#4A90E2" FontFamily="Consolas"
                                   FontSize="52" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Metric Tons (MT)" Foreground="#9DA3C0"
                                   FontFamily="Segoe UI" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Status -->
                        <TextBlock Text="{Binding Status}" Foreground="#9DA3C0"
                                   FontFamily="Segoe UI" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Stage badge -->
                        <Border CornerRadius="6" Padding="14,12" Margin="0,0,0,20"
                                Background="#252B50">
                            <StackPanel>
                                <TextBlock Text="Current Stage" Foreground="#9DA3C0"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,8"/>
                                <Border CornerRadius="4" Background="#1A1F3A"
                                        Padding="10,5" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Stage}" Foreground="#4A90E2"
                                               FontSize="12" FontWeight="Bold"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Start button -->
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding StartWeighingCommand}"
                                Height="44" Margin="0,0,0,10">
                            <TextBlock Text="⚖  Start Weighing" FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Button>

                        <!-- Complete button -->
                        <Button Style="{StaticResource OutlineButtonStyle}"
                                Command="{Binding CompleteWeighmentCommand}"
                                Height="40" BorderBrush="#3A4060" Foreground="#9DA3C0">
                            <TextBlock Text="✓  Complete" FontSize="13"/>
                        </Button>

                        <!-- Weight summary -->
                        <Separator Background="#252B50" Margin="0,20,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Gross Weight:" Foreground="#9DA3C0" FontSize="11"/>
                                <TextBlock Text="{Binding GrossWeight, StringFormat='{}{0:F2} MT'}"
                                           Foreground="#4A90E2" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tare Weight:" Foreground="#9DA3C0" FontSize="11"/>
                                <TextBlock Text="{Binding TareWeight, StringFormat='{}{0:F2} MT'}"
                                           Foreground="#4A90E2" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Net Weight:" Foreground="#9DA3C0" FontSize="11"/>
                                <TextBlock Text="{Binding NetWeight, StringFormat='{}{0:F2} MT'}"
                                           Foreground="#2ECC71" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── RIGHT: Weighment Details form ── -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Weighment Details" FontFamily="Segoe UI"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#1A1F3A"
                                   Margin="0,0,0,20"/>

                        <!-- Type -->
                        <TextBlock Text="WEIGHMENT TYPE *" Style="{StaticResource InputLabelStyle}"/>
                        <ComboBox Style="{StaticResource DPComboBoxStyle}"
                                  ItemsSource="{Binding WeighmentTypes}"
                                  SelectedItem="{Binding WeighmentType}"
                                  Margin="0,4,0,16"/>

                        <!-- Vehicle + Driver -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="16"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="VEHICLE NUMBER *" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox Style="{StaticResource DPTextBoxStyle}"
                                         Text="{Binding VehicleNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DRIVER NAME *" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox Style="{StaticResource DPTextBoxStyle}"
                                         Text="{Binding DriverName, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Container -->
                        <TextBlock Text="CONTAINER NUMBER (OPTIONAL)" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Style="{StaticResource DPTextBoxStyle}"
                                 Text="{Binding ContainerNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,16"/>

                        <!-- Material + Supplier -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="16"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="MATERIAL *" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox Style="{StaticResource DPTextBoxStyle}"
                                         Text="{Binding Material, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SUPPLIER *" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox Style="{StaticResource DPTextBoxStyle}"
                                         Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Weight Summary -->
                        <Border CornerRadius="8" Background="#F8F9FC"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="20,16">
                            <Grid>
                                <TextBlock Text="Weight Summary" FontFamily="Segoe UI"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#1A1F3A"
                                           VerticalAlignment="Top" Margin="0,0,0,16"/>
                                <UniformGrid Columns="3" Margin="0,32,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Gross" Foreground="#8A8E9B" FontSize="12"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding GrossWeight, StringFormat='{}{0:F2}'}"
                                                   FontSize="22" FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="MT" Foreground="#8A8E9B" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Tare" Foreground="#8A8E9B" FontSize="12"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding TareWeight, StringFormat='{}{0:F2}'}"
                                                   FontSize="22" FontWeight="Bold" Foreground="#1A1F3A"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="MT" Foreground="#8A8E9B" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Net" Foreground="#8A8E9B" FontSize="12"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding NetWeight, StringFormat='{}{0:F2}'}"
                                                   FontSize="22" FontWeight="Bold" Foreground="#2ECC71"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="MT" Foreground="#8A8E9B" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!-- Complete Weighment button -->
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CompleteWeighmentCommand}"
                                Height="46" Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊙  " FontSize="14"/>
                                <TextBlock Text="Complete Weighment" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
