<UserControl x:Class="WeighBridge.Views.UserControls.WeighingConsoleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="#F4F6F9">

    <UserControl.Resources>
        <!-- ── Couleurs ── -->
        <SolidColorBrush x:Key="PrimaryBrush"    Color="#E74C3C"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#0288D1"/>
        <SolidColorBrush x:Key="SuccessBrush"    Color="#27AE60"/>
        <SolidColorBrush x:Key="WarningBrush"    Color="#F57F17"/>
        <SolidColorBrush x:Key="DangerBrush"     Color="#C62828"/>
        <SolidColorBrush x:Key="CardBrush"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"     Color="#CFD8DC"/>
        <SolidColorBrush x:Key="MutedBrush"      Color="#78909C"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#263238"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#546E7A"/>

        <!-- ── Card style ── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                      Color="#22000000" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Label style ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Foreground"       Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"           Value="0,0,0,3"/>
            <Setter Property="Text"    Value="Uppercase"/>
        </Style>

        <!-- ── TextBox style ── -->
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Height"           Value="34"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Background"       Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ComboBox style ── -->
        

        <!-- ── Button base ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"           Value="36"/>
            <Setter Property="Padding"          Value="18,0"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource SuccessBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>
        <Style x:Key="BtnWarning" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource WarningBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>
        <Style x:Key="BtnDanger"  TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <!-- ── Weight display ── -->
        <Style x:Key="WeightValue" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="42"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <!-- ── Step badge ── -->
        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="10,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="20" MaxWidth="1200">

            <!-- ══════════════════════  HEADER  ══════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Weighing Console"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Weightbridge — DPWorld Algiers"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="14" Padding="14,6"
                        VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWeighing}" Value="True">
                                        <Setter Property="Background" Value="#FFF8E1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWeighing}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding Status}" FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWeighing}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════  MODE TOGGLE  ══════════════════════ -->


            <!-- ══════════════  LAYOUT PRINCIPAL : DISPLAY gauche | FORM droite  ══════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ════════════  COLONNE GAUCHE : LIVE WEIGHT DISPLAY  ════════════ -->
                <Border Grid.Column="0" CornerRadius="8" Background="#1E2A45" Padding="20"
                    VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="3"
                                      Color="#11000000" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Titre -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Ellipse Width="8" Height="8" Fill="#4FC3F7"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Live Weight Display"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#B0BEC5"/>
                        </StackPanel>

                        <!-- ── MODE SIMPLE ── -->
                        <StackPanel Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibility}}">
                            <Border CornerRadius="4" Padding="12,6"
                                HorizontalAlignment="Stretch" Margin="0,0,0,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1565C0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SingleModeStep}" Value="2">
                                                <Setter Property="Background" Value="#1B5E20"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SingleModeStep}" Value="3">
                                                <Setter Property="Background" Value="#E65100"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SingleModeStep}" Value="4">
                                                <Setter Property="Background" Value="#4A148C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SingleModeStageLabel}"
                                       FontSize="11" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock Text="Current Weight" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#546E7A" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding LiveWeight, StringFormat='{}{0:F2}'}"
                                       FontSize="52" FontWeight="Bold" Foreground="#4FC3F7"/>
                            </StackPanel>
                            <TextBlock Text="Tons" FontSize="12" Foreground="#546E7A"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Stage}" FontSize="12" Foreground="#90A4AE"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- Stage Badge -->
                            <Border CornerRadius="4" Padding="12,5"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1565C0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Stage}" Value="TARE WEIGHT">
                                                <Setter Property="Background" Value="#1B5E20"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Stage}" Value="TERMINÉ">
                                                <Setter Property="Background" Value="#4A148C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Stage}"
                                       FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </Border>

                            <!-- Boutons simple -->
                            <Button Content="▶  Start Weighing"
                                Command="{Binding StartSingleModeCommand}"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#263350" CornerRadius="6" Padding="12,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="✔  Confirm the weight"
                                Command="{Binding ConfirmSingleModeCommand}"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#1B3A2A" CornerRadius="6" Padding="12,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="↺  Reset"
                                Command="{Binding ResetSingleModeCommand}"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#4A1515" CornerRadius="6" Padding="12,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Separator Background="#2A3A55" Margin="0,0,0,12"/>

                            <!-- Gross / Tare / Net -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Gross Weight:" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding GrossWeight, StringFormat='{}{0:F2} '}"
                                           FontSize="13" FontWeight="Bold" Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Tare Weight:" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TareWeight, StringFormat='{}{0:F2} '}"
                                           FontSize="13" FontWeight="Bold" Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Net Weight:" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetWeight, StringFormat='{}{0:F2} '}"
                                           FontSize="13" FontWeight="Bold" Foreground="#00E676" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>

                        <!-- ── MODE DUAL 20' ── -->
                        <StackPanel Visibility="{Binding IsDual20Mode, Converter={StaticResource BoolToVisibility}}">

                            <!-- Badge étape -->
                            <Border CornerRadius="4" Padding="12,6"
                                HorizontalAlignment="Stretch" Margin="0,0,0,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1565C0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Dual20Step}" Value="2">
                                                <Setter Property="Background" Value="#1B5E20"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Dual20Step}" Value="3">
                                                <Setter Property="Background" Value="#E65100"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Dual20Step}" Value="4">
                                                <Setter Property="Background" Value="#4A148C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Dual20StageLabel}"
                                       FontSize="11" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Poids live -->
                            <TextBlock Text="Current Weight" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#546E7A" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding LiveWeight, StringFormat='{}{0:F2}'}"
                                       FontSize="52" FontWeight="Bold" Foreground="#4FC3F7"/>
                            </StackPanel>
                            <TextBlock Text="Tons" FontSize="12" Foreground="#546E7A"
                                   HorizontalAlignment="Center" Margin="0,4,0,16"/>

                            <!-- 3 étapes -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="6" Padding="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#162035"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Dual20Step}" Value="1">
                                                    <Setter Property="Background" Value="#1565C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="① N1" FontSize="10" FontWeight="Bold"
                                               Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                                        <TextBlock Text="CTN1+CTN2" FontSize="9" Foreground="#90A4AE"
                                               HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding GrossWeightN1, StringFormat='{}{0:F2}'}"
                                               FontSize="12" FontWeight="Bold" Foreground="#4FC3F7"
                                               HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Column="1" Text="→" FontSize="14" Foreground="#546E7A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Border Grid.Column="2" CornerRadius="6" Padding="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#162035"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Dual20Step}" Value="2">
                                                    <Setter Property="Background" Value="#1B5E20"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="② N2" FontSize="10" FontWeight="Bold"
                                               Foreground="#66BB6A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="CTN2 alone" FontSize="9" Foreground="#90A4AE"
                                               HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding IntermediateWeightN1, StringFormat='{}{0:F2}'}"
                                               FontSize="12" FontWeight="Bold" Foreground="#66BB6A"
                                               HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Column="3" Text="→" FontSize="14" Foreground="#546E7A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Border Grid.Column="4" CornerRadius="6" Padding="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#162035"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Dual20Step}" Value="3">
                                                    <Setter Property="Background" Value="#E65100"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="③ TARE" FontSize="10" FontWeight="Bold"
                                               Foreground="#FFA726" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Empty" FontSize="9" Foreground="#90A4AE"
                                               HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding TareWeightN2, StringFormat='{}{0:F2}'}"
                                               FontSize="12" FontWeight="Bold" Foreground="#FFA726"
                                               HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Boutons dual -->
                            <Button Content="▶  Start Weighing"
                                Command="{Binding StartDual20Command}"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#263350" CornerRadius="6" Padding="12,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="✔  Confirme the weight"
                                Command="{Binding ConfirmDual20Command}"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#1B3A2A" CornerRadius="6" Padding="12,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="↺  Reset"
                                Command="{Binding ResetDual20Command}"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#4A1515" CornerRadius="6" Padding="12,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Separator Background="#2A3A55" Margin="0,0,0,12"/>

                            <!-- Net CTN1 / Net CTN2 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Net CTN1:" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetWeightCtn1, StringFormat='{}{0:F2} '}"
                                           FontSize="16" FontWeight="Bold" Foreground="#00E676" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ContainerNumber}" FontSize="10"
                                           Foreground="#546E7A" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Net CTN2:" FontSize="10" Foreground="#546E7A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetWeightCtn2, StringFormat='{}{0:F2} '}"
                                           FontSize="16" FontWeight="Bold" Foreground="#00E676" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ContainerNumber2}" FontSize="10"
                                           Foreground="#546E7A" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ════════════  COLONNE DROITE : FORM  ════════════ -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Mode :" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <RadioButton Content="Simple weighing"
                             IsChecked="{Binding IsSingleMode, Mode=OneWay}"
                             Command="{Binding ToggleModeCommand}"
                             CommandParameter="Single"
                             FontSize="13" VerticalAlignment="Center"
                             Margin="0,0,20,0"/>
                            <RadioButton Content="Weighing two containers 20'"
                             IsChecked="{Binding IsDual20Mode}"
                             Command="{Binding ToggleModeCommand}"
                             CommandParameter="Dual20"
                             FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Informations opération -->
                    <!-- Informations opération -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Operator information"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}"
                   Margin="0,0,0,12"/>

                            <!-- Ligne 1 : Type | N° Véhicule + Vérifier | Chauffeur -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Type — read only après autorisation -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Style="{StaticResource ComboType}" ItemsSource="{Binding WeighmentTypes}"
                          SelectedItem="{Binding WeighmentType}"
                          IsEnabled="{Binding IsAuthorized, 
                              Converter={StaticResource InverseBool}}"/>
                                </StackPanel>

                                <!-- N° Véhicule + bouton Vérifier -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="N° Véhicule*" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                             Style="{StaticResource Field}"
                             Text="{Binding VehicleNumber, 
                                 UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsAuthorized, 
                                Converter={StaticResource InverseBool}}"/>
                                        <Button Grid.Column="2"
                            Height="34" Padding="10,0"
                            FontSize="12" FontWeight="SemiBold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding CheckAuthorizationCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnBase}">
                                                    <Setter Property="Background" Value="#0288D1"/>
                                                    <Setter Property="Content" Value="Vérifier"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheckingAuth}" Value="True">
                                                            <Setter Property="Content" Value="…"/>
                                                            <Setter Property="Background" Value="#78909C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- Chauffeur — rempli par Zodiac -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Chauffeur*" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource Field}"
                         Text="{Binding DriverName, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsAuthorized}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Ligne Client -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Client*" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource Field}"
                         Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsAuthorized}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Société" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource Field}"
                         Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"/>
                                </StackPanel>
                            </Grid>

                            <!-- ── Bandeau Zodiac Authorization ── -->
                            <Border Margin="0,10,0,0" Padding="12,8" CornerRadius="6"
                Visibility="{Binding IsAuthStatusVisible, 
                    Converter={StaticResource BoolToVisibility}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"    Value="#1B2E1B"/>
                                        <Setter Property="BorderBrush"   Value="#4CAF50"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAuthorized}" Value="False">
                                                <Setter Property="Background"    Value="#2E1B1B"/>
                                                <Setter Property="BorderBrush"   Value="#EF5350"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✔"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthorized}" Value="False">
                                                        <Setter Property="Text" Value="✖"/>
                                                        <Setter Property="Foreground" Value="#EF5350"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding AuthStatus}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthorized}" Value="False">
                                                        <Setter Property="Foreground" Value="#EF5350"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Infos Zodiac (visibles seulement si autorisé) -->
                                    <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsAuthorized, 
                                Converter={StaticResource BoolToVisibility}}"
                            Margin="20,0,0,0">
                                        <TextBlock Text="{Binding CompanyName}" 
                               Foreground="#90A4AE" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding BookingNumber}" 
                               Foreground="#90A4AE" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Foreground="#90A4AE" FontSize="12" VerticalAlignment="Center">
                        <Run Text="Tare Zodiac : "/>
                        <Run Text="{Binding ZodiacTareWeight, StringFormat='{}{0:N0} kg'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Ligne 2 : Conteneur | Conteneur2 | Material -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
                                                <Setter Property="Text" Value="N° Container*"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDual20Mode}" Value="True">
                                                        <Setter Property="Text" Value="N° Conteneur 1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Style="{StaticResource Field}"
                         Text="{Binding ContainerNumber, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsAuthorized}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                        Visibility="{Binding IsDual20Mode, 
                            Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="N° Container 2*" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource Field}"
                         Text="{Binding ContainerNumber2, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Material*" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Style="{StaticResource Field}"
                         Text="{Binding Material, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Weight Summary -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Weight Summary"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,12"/>

                            <!-- Mode simple -->
                            <Grid Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Gross" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding GrossWeight, StringFormat='{}{0:F2}'}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tons" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Tare" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TareWeight, StringFormat='{}{0:F2}'}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tons" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Net" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetWeight, StringFormat='{}{0:F2}'}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tons" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Mode dual -->
                            <Grid Visibility="{Binding IsDual20Mode, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Gross Weight" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding GrossWeightN1, StringFormat='{}{0:F2}'}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tons" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Net CTN1" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetWeightCtn1, StringFormat='{}{0:F2}'}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tons" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Net CTN2" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetWeightCtn2, StringFormat='{}{0:F2}'}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tons" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Print Buttons ── -->
                    <!-- Import ticket: visible only when WeighmentType = Import -->
                    <Button Margin="0,16,0,0"
                            Height="38" FontSize="13" FontWeight="SemiBold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding PrintImportTicketCommand}"
                            Content="🖨  Print Import Ticket">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WeighmentType}" Value="Import">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Export ticket: visible only when WeighmentType = Export -->
                    <Button Margin="0,16,0,0"
                            Height="38" FontSize="13" FontWeight="SemiBold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding PrintVGMCommand}"
                            Content="🖨  Print Export Ticket (VGM)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnSuccess}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WeighmentType}" Value="Export">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Grid>

        </StackPanel>
        
    </ScrollViewer>
</UserControl>