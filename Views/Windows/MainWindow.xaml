<Window x:Class="WeighBridge.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DP World – WeighBridge Management System"
        Width="1400" Height="820"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource ContentBgBrush}">

    <!--
    ╔════════════════════════════════════════════════════════╗
    ║  Row 0 │ Col 0 : Logo + DP World  (constant)          ║
    ║  Row 0 │ Col 1 : NavBar           (injected in CS)    ║
    ║  Row 1 │ Col 0 : SideBar          (injected in CS)    ║
    ║  Row 1 │ Col 1 : Content Page     (injected in CS)    ║
    ╚════════════════════════════════════════════════════════╝
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Row 0 · Col 0 — Logo (pure XAML, no UserControl) ══ -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}"
                BorderBrush="#0D1128" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="16,0">
                <Image Source="/Assets/Images/Logotype_de_DP_World3.png" Width="130"/>
            </StackPanel>
        </Border>

        <!-- ══ Row 0 · Col 1 — NavBar placeholder ══ -->
        <ContentControl x:Name="NavBarHost"
                        Grid.Row="0" Grid.Column="1"/>

        <!-- ══ Row 1 · Col 0 — SideBar placeholder ══ -->
        <ContentControl x:Name="SideBarHost"
                        Grid.Row="1" Grid.Column="0"/>

        <!-- ══ Row 1 · Col 1 — Active Page placeholder ══ -->
        <ContentControl x:Name="PageHost"
                        Grid.Row="1" Grid.Column="1"/>
    </Grid>
</Window>
